{
  "name": "vorker-2",
  "version": "1.0.0",
  "description": "Terminal-first Copilot supervisor with a shared event model, web control plane, and Cloudflare tunnel support",
  "bin": {
    "vorker": "./src/index.js"
  },
  "scripts": {
    "check": "node --check src/index.js",
    "check:server": "node --check src/index.js && node --check src/cli.js && node --check src/copilot.js && node --check src/server.js && node --check src/orchestrator.js && node --check src/git/task-workspace.js && node --check src/worktree.js && node --check src/skills.js && node --check src/tunnel.js && node --check src/share.js && node --check src/tailscale.js",
    "check:web": "next build",
    "check:all": "npm run check:server && npm run check:web",
    "rust:check": "source \"$HOME/.cargo/env\" && cargo fmt --check && cargo clippy --workspace --all-targets -- -D warnings",
    "rust:build": "source \"$HOME/.cargo/env\" && cargo build -p vorker-cli",
    "rust:test": "source \"$HOME/.cargo/env\" && cargo test --workspace",
    "cert": "sh scripts/generate-dev-cert.sh",
    "serve": "node src/index.js serve",
    "start": "node src/index.js",
    "tailnet": "node src/index.js tailnet",
    "tui": "sh scripts/run-rust-tui.sh",
    "tui:once": "sh scripts/run-rust-tui.sh --once",
    "dev": "next dev",
    "build": "next build",
    "test:unit": "node --test tests/*.test.js",
    "test": "npm run test:unit && npm run check:all"
  },
  "keywords": [],
  "author": "",
  "license": "0BSD",
  "type": "module",
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.16.1",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-collapsible": "1.1.12",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-switch": "1.2.6",
    "@tailwindcss/postcss": "^4.2.1",
    "@xyflow/react": "^12.10.1",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "date-fns": "4.1.0",
    "lucide-react": "^0.564.0",
    "next": "^16.1.6",
    "postcss": "8.5.22",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "ws": "^8.19.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/dagre": "^0.7.52",
    "@types/node": "^22",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "tw-animate-css": "1.3.3",
    "typescript": "5.7.3"
  },
  "overrides": {
    "postcss": "8.5.22",
    "sharp": "0.35.3"
  }
}
